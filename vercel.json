{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "apps/frontend/.next",
  "framework": "nextjs",
  "functions": {
    "apps/backend/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/apps/backend/api/:path*"
    }
  ]
}
