{
  "name": "cancelai",
  "version": "1.0.0",
  "private": true,
  "description": "Cancelaí - Identificador de assinaturas recorrentes em extratos bancários",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev -w apps/backend",
    "dev:frontend": "npm run dev -w apps/frontend",
    "build": "turbo build",
    "build:backend": "turbo build --filter=@cancelai/backend",
    "build:frontend": "turbo build --filter=@cancelai/frontend",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "turbo": "^2.9.6",
    "typescript": "^5.3.3"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=18.0.0"
  }
}
