# Server
PORT=3001
HOST=0.0.0.0

# CORS - URL do frontend
# Desenvolvimento: http://localhost:3000
# Produção: https://seu-dominio.vercel.app
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=1 minute

# File Upload
MAX_FILE_SIZE=10485760
MAX_FILES=5

# DeepSeek API (opcional - refinamento com IA)
# Se não configurado, o sistema funciona normalmente sem refinamento
# IMPORTANTE: Configure esta variável na Vercel em Settings > Environment Variables
DEEPSEEK_API_KEY=
