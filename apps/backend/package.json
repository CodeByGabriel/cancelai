{
  "name": "@cancelai/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:accuracy": "vitest run test/classification-accuracy",
    "test:golden": "UPDATE_GOLDEN=true vitest run test/classification-accuracy",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.1.0",
    "csv-parse": "^5.5.3",
    "fastify": "^4.26.0",
    "fuse.js": "^7.1.0",
    "ofx-data-extractor": "^1.4.8",
    "opossum": "^9.0.0",
    "pdf-parse": "^1.1.1",
    "pluggy-sdk": "^0.85.2",
    "string-comparisons": "^0.0.20"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/opossum": "^8.1.9",
    "@types/pdf-parse": "^1.1.4",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "fast-check": "^4.5.3",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  }
}
